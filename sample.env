# Get these from https://developer.intuit.com -> My Apps -> your app -> Keys & OAuth
QB_CONSUMER_CLIENT_ID=your_client_id_here
QB_CONSUMER_CLIENT_SECRET=your_client_secret_here

# Or use the older env var names (fallback):
# QB_CONSUMER_KEY=your_client_id_here
# QB_CONSUMER_SECRET=your_client_secret_here

# Set this to your public URL for production, or keep default for localhost
QBO_REDIRECT_URI=http://localhost:3000/api/qbo/callback

# Set to 'production' when going live (default is sandbox)
QBO_ENVIRONMENT=sandbox
